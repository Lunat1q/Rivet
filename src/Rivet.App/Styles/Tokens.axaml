<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
      One palette, defined once. Rivet makes short-form video, so the accent is the same hot
      magenta→violet that reads as "creator tool". Everything else is near-black and grey: the
      video preview and the one button you press should be the only things with colour.
    -->

    <!-- Surfaces -->
    <Color x:Key="BgColor">#0C0D12</Color>
    <Color x:Key="SurfaceColor">#14151D</Color>
    <Color x:Key="SurfaceRaisedColor">#1D1F2A</Color>
    <Color x:Key="BorderColor">#2C2F3C</Color>

    <SolidColorBrush x:Key="Bg" Color="{StaticResource BgColor}" />
    <SolidColorBrush x:Key="Surface" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceRaised" Color="{StaticResource SurfaceRaisedColor}" />
    <SolidColorBrush x:Key="Border" Color="{StaticResource BorderColor}" />

    <!-- Text -->
    <SolidColorBrush x:Key="Text" Color="#ECEDF2" />
    <SolidColorBrush x:Key="TextMuted" Color="#8A90A2" />
    <SolidColorBrush x:Key="TextFaint" Color="#5A6070" />

    <!-- Accent -->
    <SolidColorBrush x:Key="Accent" Color="#E5399A" />
    <SolidColorBrush x:Key="AccentHover" Color="#F24FAD" />
    <SolidColorBrush x:Key="AccentSoft" Color="#2A1226" />
    <SolidColorBrush x:Key="Go" Color="#E5399A" />
    <SolidColorBrush x:Key="GoHover" Color="#F24FAD" />
    <SolidColorBrush x:Key="Warn" Color="#F5C451" />
    <SolidColorBrush x:Key="WarnSoft" Color="#2E2716" />
    <SolidColorBrush x:Key="Danger" Color="#E5484D" />

    <!-- Geometry -->
    <CornerRadius x:Key="RadiusCard">14</CornerRadius>
    <CornerRadius x:Key="RadiusControl">8</CornerRadius>
    <CornerRadius x:Key="RadiusPill">999</CornerRadius>

</ResourceDictionary>
